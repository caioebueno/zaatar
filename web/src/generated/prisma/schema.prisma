// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model Station {
  id               String            @id
  name             String
  preparationSteps PreparationStep[]
}

model PreparationStep {
  id                    String                 @id
  createdAt             DateTime               @default(now())
  name                  String
  includeComments       Boolean                @default(false)
  includeModifiers      Boolean                @default(false)
  products              Product[]
  station               Station                @relation(fields: [stationId], references: [id])
  stationId             String
  preparationStepTracks PreparationStepTrack[]
}

model PreparationStepCategory {
  id                    String                 @id
  createdAt             DateTime               @default(now())
  category              Category?              @relation(fields: [categoryId], references: [id])
  categoryId            String?
  completed             Boolean                @default(false)
  order                 Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId               String
  preparationStepTracks PreparationStepTrack[]
}

model PreparationStepTrack {
  id                            String                         @id
  createdAt                     DateTime                       @default(now())
  completed                     Boolean                        @default(false)
  quantity                      Int?
  comments                      String?
  completedComments             Boolean                        @default(false)
  preparationStepModifierTracks PreparationStepModifierTrack[]
  preparationStep               PreparationStep                @relation(fields: [preparationStepId], references: [id])
  preparationStepId             String
  preparationStepCategory       PreparationStepCategory        @relation(fields: [preparationStepCategoryId], references: [id], onDelete: Cascade)
  preparationStepCategoryId     String
}

model PreparationStepModifierTrack {
  id                     String               @id
  createdAt              DateTime             @default(now())
  completed              Boolean              @default(false)
  modifierGroupItem      ModifierGroupItem    @relation(fields: [modifierGroupItemId], references: [id])
  modifierGroupItemId    String
  preparationStepTrack   PreparationStepTrack @relation(fields: [preparationStepTrackId], references: [id], onDelete: Cascade)
  preparationStepTrackId String
}

model ProgressiveDiscount {
  id        String                    @id
  createdAt DateTime                  @default(now())
  completed Boolean                   @default(false)
  steps     ProgressiveDiscountStep[]
}

enum ProgressiveDiscountStepType {
  PERCENTAGEDISCOUNT
  GIFT
}

model ProgressiveDiscountStep {
  id                    String                      @id
  createdAt             DateTime                    @default(now())
  amount                Int
  discount              Int?
  discountType          ProgressiveDiscountStepType
  progressiveDiscount   ProgressiveDiscount         @relation(fields: [progressiveDiscountId], references: [id])
  progressiveDiscountId String
  prizes                ProgressiveDiscountPrize[]
}

model ProgressiveDiscountPrize {
  id                        String                            @id
  createdAt                 DateTime                          @default(now())
  name                      String
  translations              Json?
  quantity                  Int                               @default(1)
  imageUrl                  String?
  progressiveDiscountStep   ProgressiveDiscountStep           @relation(fields: [progressiveDiscountStepId], references: [id], onDelete: Cascade)
  progressiveDiscountStepId String
  products                  ProgressiveDiscountPrizeProduct[]
}

model ProgressiveDiscountPrizeProduct {
  id        String                   @id
  createdAt DateTime                 @default(now())
  prize     ProgressiveDiscountPrize @relation(fields: [prizeId], references: [id], onDelete: Cascade)
  prizeId   String
  product   Product                  @relation(fields: [productId], references: [id])
  productId String

  @@unique([prizeId, productId])
}

model File {
  id                 String              @id
  createdAt          DateTime            @default(now())
  name               String
  url                String
  size               Int
  product            Product?            @relation(fields: [productId], references: [id])
  productId          String?
  modifierGroupItems ModifierGroupItem[]
}

model ModifierGroup {
  id           String              @id
  createdAt    DateTime            @default(now())
  title        String
  translations Json?
  required     Boolean             @default(false)
  type         ModifierGroupType?
  products     Product[]
  items        ModifierGroupItem[]
  minSelection Int?
  maxSelection Int?
}

model ModifierGroupItem {
  id                            String                         @id
  createdAt                     DateTime                       @default(now())
  name                          String
  price                         Int
  description                   String?
  translations                  Json?
  photo                         File?                          @relation(fields: [fileId], references: [id])
  modifierGroup                 ModifierGroup?                 @relation(fields: [modifierGroupId], references: [id])
  modifierGroupId               String?
  fileId                        String?
  preparationStepModifierTracks PreparationStepModifierTrack[]
  orderProducts                 OrderProducts[]
}

enum ModifierGroupType {
  MULTI
  SINGLE
}

model Business {
  id        String          @id
  createdAt DateTime        @default(now())
  name      String
  branches  Branch[]
  owners    BusinessOwner[]
}

model User {
  id              String          @id
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  email           String          @unique
  name            String
  passwordHash    String
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  ownedBusinesses BusinessOwner[]
}

model BusinessOwner {
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime @default(now())

  @@id([businessId, userId])
  @@index([userId])
}

model Branch {
  id             String    @id
  createdAt      DateTime  @default(now())
  name           String
  operationHours Json?
  address        Address?  @relation(fields: [addressId], references: [id])
  addressId      String?   @unique
  business       Business? @relation(fields: [businessId], references: [id])
  businessId     String?
}

model Driver {
  id            String     @id
  createdAt     DateTime   @default(now())
  name          String
  active        Boolean    @default(true)
  priorityLevel Int
  dispatches    Dispatch[]
}

model Dispatch {
  id                                String    @id
  createdAt                         DateTime  @default(now())
  queueIndex                        Int?
  dispatched                        Boolean   @default(false)
  dispatchAt                        DateTime?
  estimatedDeliveryDurationMinutes  Int?
  estimatedRoundTripDurationMinutes Int?
  driver                            Driver?   @relation(fields: [driverId], references: [id])
  driverId                          String?
  orders                            Order[]

  @@index([queueIndex])
}

enum DispatchAssignmentJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model DispatchAssignmentJob {
  id                  String                      @id
  createdAt           DateTime                    @default(now())
  status              DispatchAssignmentJobStatus @default(PENDING)
  attempts            Int                         @default(0)
  availableAt         DateTime                    @default(now())
  processingStartedAt DateTime?
  completedAt         DateTime?
  lastError           String?
  orderId             String                      @unique
  deliveryAddressId   String
}

model Address {
  id            String   @id
  createdAt     DateTime @default(now())
  description   String
  googleMapsUrl String
  branch        Branch?
  orders        Order[]
}

model Product {
  id                         String                            @id
  createdAt                  DateTime                          @default(now())
  itemType                   ProductItemType                   @default(PRODUCT)
  name                       String
  visible                    Boolean                           @default(true)
  description                String?
  price                      Int?
  comparedAtPrice            Int?
  categoryIndex              Int?
  photos                     File[]
  modifierGroups             ModifierGroup[]
  category                   Category?                         @relation(fields: [categoryId], references: [id])
  categoryId                 String?
  productCategories          ProductCategory[]
  comboSlots                 ComboSlot[]                       @relation("ComboProduct")
  comboSlotOptions           ComboSlotOption[]                 @relation("ComboOptionProduct")
  exclusivePromotionProducts ExclusivePromotionProduct[]
  OrderProducts              OrderProducts[]
  prizeProducts              ProgressiveDiscountPrizeProduct[]
  translations               Json?
  preparationSteps           PreparationStep[]

  @@index([categoryId, categoryIndex])
}

model ExclusivePromotion {
  id            String                      @id
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  name          String
  active        Boolean                     @default(true)
  expireAt      DateTime?
  validWeekdays ExclusivePromotionWeekday[] @default([])
  products      ExclusivePromotionProduct[]
  menuVisits    MenuVisit[]
}

enum ExclusivePromotionWeekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model ExclusivePromotionProduct {
  promotion   ExclusivePromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  promotionId String
  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  createdAt   DateTime           @default(now())

  @@id([promotionId, productId])
  @@index([productId])
}

enum ProductItemType {
  PRODUCT
  COMBO
}

model Menu {
  id             String         @id
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  name           String
  active         Boolean        @default(true)
  isDefault      Boolean        @default(false)
  categories     Category[]
  menuCategories MenuCategory[]
  menuVisits     MenuVisit[]

  @@index([isDefault])
}

model MenuVisit {
  id          String              @id
  createdAt   DateTime            @default(now())
  visitorId   String
  visitKey    String
  menu        Menu?               @relation(fields: [menuId], references: [id], onDelete: SetNull)
  menuId      String?
  promotion   ExclusivePromotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  promotionId String?
  language    String?
  pathname    String
  referrer    String?
  userAgent   String?
  ipAddress   String?

  @@unique([visitorId, visitKey])
  @@index([createdAt])
  @@index([menuId, createdAt])
  @@index([promotionId, createdAt])
}

model Category {
  id                        String                    @id
  createdAt                 DateTime                  @default(now())
  name                      String
  menu                      Menu                      @relation(fields: [menuId], references: [id])
  menuId                    String
  menuIndex                 Int?
  translations              Json?
  products                  Product[]
  productCategories         ProductCategory[]
  menuCategories            MenuCategory[]
  preparationStepCategories PreparationStepCategory[]

  @@index([menuId, menuIndex])
}

model MenuCategory {
  menu       Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId     String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String
  menuIndex  Int?
  createdAt  DateTime @default(now())

  @@id([menuId, categoryId])
  @@index([menuId, menuIndex])
  @@index([categoryId])
}

model ProductCategory {
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     String
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId    String
  categoryIndex Int?
  createdAt     DateTime @default(now())

  @@id([productId, categoryId])
  @@index([categoryId, categoryIndex])
  @@index([productId])
}

model ComboSlot {
  id              String            @id
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  combo           Product           @relation("ComboProduct", fields: [comboId], references: [id], onDelete: Cascade)
  comboId         String
  name            String
  translations    Json?
  minSelect       Int               @default(1)
  maxSelect       Int               @default(1)
  allowDuplicates Boolean           @default(true)
  sortIndex       Int?
  options         ComboSlotOption[]

  @@index([comboId, sortIndex])
}

model ComboSlotOption {
  id         String    @id
  createdAt  DateTime  @default(now())
  slot       ComboSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  slotId     String
  product    Product   @relation("ComboOptionProduct", fields: [productId], references: [id], onDelete: Restrict)
  productId  String
  extraPrice Int       @default(0)
  sortIndex  Int?

  @@unique([slotId, productId])
  @@index([slotId, sortIndex])
  @@index([productId])
}

model Campaign {
  id                String             @id
  createdAt         DateTime           @default(now())
  startedAt         DateTime?
  promotialMessages PromotialMessage[]
}

model Customer {
  id                  String             @id
  createdAt           DateTime           @default(now())
  name                String?
  email               String?
  phone               String?
  address             String?
  lastMessageSent     DateTime?
  orders              Order[]
  promotionalMessages PromotialMessage[]
  addresses           DeliveryAddress[]
  externalAddresses   ExternalAddress[]
}

model DeliveryAddress {
  id               String    @id
  createdAt        DateTime  @default(now())
  lat              String
  lng              String
  deliveryFee      Int       @default(0)
  city             String
  zipCode          String
  State            String
  street           String
  number           String
  description      String
  complement       String?
  numberComplement String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  customerId       String?
  orders           Order[]
}

model ExternalAddress {
  id         String    @id
  createdAt  DateTime  @default(now())
  address    String?
  lat        String?
  lng        String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  orders     Order[]

  @@index([customerId])
}

model Message {
  id                String             @id
  createdAt         DateTime           @default(now())
  name              String             @unique
  promotialMessages PromotialMessage[]
  content           String
  media             String?
}

model PromotialMessage {
  id         String    @id
  sentAt     DateTime  @default(now())
  Campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?
  message    Message   @relation(fields: [messageId], references: [id])
  messageId  String
  Customer   Customer  @relation(fields: [customerId], references: [id])
  customerId String
}

model Order {
  id                               String                    @id
  number                           String?
  createdAt                        DateTime                  @default(now())
  scheduleFor                      DateTime?
  language                         String?
  paidAt                           DateTime?
  deliveredAt                      DateTime?
  estimatedDeliveryDurationMinutes Int?
  dispatchOrderIndex               Int?
  amount                           Int
  canceled                         Boolean                   @default(false)
  customer                         Customer?                 @relation(fields: [customerId], references: [id])
  status                           OrderStatus               @default(ACCEPTED)
  type                             OrderType                 @default(DELIVERY)
  paymentMethod                    PaymentType               @default(CARD)
  tipAmount                        Int?
  tags                             String[]                  @default([])
  progressiveDiscountSnapshot      Json?
  dispatch                         Dispatch?                 @relation(fields: [dispatchId], references: [id])
  address                          Address?                  @relation(fields: [addressId], references: [id])
  deliveryAddress                  DeliveryAddress?          @relation(fields: [deliveryAddressId], references: [id])
  externalAddress                  ExternalAddress?          @relation(fields: [externalAddressId], references: [id])
  orderProducts                    OrderProducts[]
  customerId                       String?
  externalId                       String?                   @unique
  dispatchId                       String?
  addressId                        String?
  deliveryAddressId                String?
  externalAddressId                String?
  preparationStepCategories        PreparationStepCategory[]

  @@index([dispatchId, dispatchOrderIndex])
}

enum PaymentType {
  CASH
  CARD
  ZELLE
}

enum OrderType {
  DELIVERY
  TAKEAWAY
}

enum OrderStatus {
  ACCEPTED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
}

model OrderProducts {
  id                 String              @id
  createdAt          DateTime            @default(now())
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId          String
  quantity           Int
  comments           String?
  modifierGroupItems ModifierGroupItem[]
  fullAmount         Int
  amount             Int
  order              Order?              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId            String?
}

enum InventoryPlaceType {
  FRIDGE
  FREEZER
  SHELF
  PANTRY
  OTHER
}

enum InventoryChecklistStatus {
  OPEN
  SUBMITTED
  REVIEWED
}

enum InventoryChecklistItemResult {
  PENDING
  OK
  BELOW_MIN
  REFILL_NEEDED
  OUT_OF_STOCK
}

enum InventoryAlertType {
  LOW_STOCK
  THRESHOLD
  REFILL
}

enum InventoryAlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum InventoryAlertStatus {
  OPEN
  ACKED
  RESOLVED
}

model InventoryPlace {
  id             String                   @id
  createdAt      DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                 @updatedAt @db.Timestamptz(6)
  name           String
  type           String
  active         Boolean                  @default(true)
  displayOrder   Int?
  notes          String?
  stocks         InventoryStock[]
  alerts         InventoryAlert[]
  checklistItems InventoryChecklistItem[]
  stockEvents    InventoryStockEvent[]
}

model InventoryProduct {
  id             String                   @id
  createdAt      DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                 @updatedAt @db.Timestamptz(6)
  name           String
  unit           String
  active         Boolean                  @default(true)
  minQuantity    Int                      @default(0)
  alertThreshold Int?
  requiresRefill Boolean                  @default(false)
  notes          String?
  stocks         InventoryStock[]
  alerts         InventoryAlert[]
  checklistItems InventoryChecklistItem[]
  stockEvents    InventoryStockEvent[]
}

model InventoryStock {
  id                   String           @id
  createdAt            DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime         @updatedAt @db.Timestamptz(6)
  place                InventoryPlace   @relation(fields: [placeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  placeId              String
  product              InventoryProduct @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productId            String
  currentQuantity      Int              @default(0)
  minQuantity          Int              @default(0)
  notifyBelowThreshold Boolean          @default(false)
  includeInChecklist   Boolean          @default(true)
  lastCheckedAt        DateTime?        @db.Timestamptz(6)
  lastCheckedBy        String?

  @@unique([placeId, productId])
}

model InventoryChecklist {
  id          String                   @id
  createdAt   DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime                 @updatedAt @db.Timestamptz(6)
  checkDate   DateTime                 @db.Date
  status      String                   @default("OPEN")
  startedBy   String?
  submittedBy String?
  submittedAt DateTime?                @db.Timestamptz(6)
  items       InventoryChecklistItem[]
  alerts      InventoryAlert[]

  @@unique([checkDate])
}

model InventoryChecklistItem {
  id                  String             @id
  createdAt           DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @db.Timestamptz(6)
  checklist           InventoryChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  checklistId         String
  place               InventoryPlace     @relation(fields: [placeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  placeId             String
  product             InventoryProduct   @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  productId           String
  expectedMinQuantity Int                @default(0)
  countedQuantity     Int?
  outOfStock          Boolean            @default(false)
  result              String             @default("PENDING")
  notes               String?
  checkedAt           DateTime?          @db.Timestamptz(6)
  checkedBy           String?
  alerts              InventoryAlert[]

  @@unique([checklistId, productId, placeId], map: "InventoryChecklistItem_checklistId_productId_placeId_key")
}

model InventoryAlert {
  id              String                  @id
  createdAt       DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(6)
  type            String
  severity        String
  status          String                  @default("OPEN")
  message         String
  place           InventoryPlace          @relation(fields: [placeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  placeId         String
  product         InventoryProduct        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productId       String
  checklist       InventoryChecklist?     @relation(fields: [checklistId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  checklistId     String?
  checklistItem   InventoryChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  checklistItemId String?
  triggeredAt     DateTime                @default(now()) @db.Timestamptz(6)
  ackedAt         DateTime?               @db.Timestamptz(6)
  ackedBy         String?
  resolvedAt      DateTime?               @db.Timestamptz(6)
  resolvedBy      String?

  @@index([status, type], map: "InventoryAlert_status_idx")
}

model InventoryStockEvent {
  id             String           @id
  createdAt      DateTime         @default(now()) @db.Timestamptz(6)
  eventType      String
  place          InventoryPlace   @relation(fields: [placeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  placeId        String
  product        InventoryProduct @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productId      String
  beforeQuantity Int?
  afterQuantity  Int?
  actorId        String?
  source         String
  metadata       Json?

  @@index([placeId, productId, createdAt], map: "InventoryStockEvent_placeId_productId_createdAt_idx")
}
