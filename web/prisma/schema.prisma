// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model Station {
  id               String            @id
  name             String
  preparationSteps PreparationStep[]
}

model PreparationStep {
  id                    String                 @id
  createdAt             DateTime               @default(now())
  name                  String
  includeComments       Boolean                @default(false)
  includeModifiers      Boolean                @default(false)
  products              Product[]
  station               Station                @relation(fields: [stationId], references: [id])
  stationId             String
  preparationStepTracks PreparationStepTrack[]
}

model PreparationStepCategory {
  id                    String                 @id
  createdAt             DateTime               @default(now())
  category              Category?               @relation(fields: [categoryId], references: [id])
  categoryId            String?
  completed             Boolean                @default(false)
  order                 Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId               String
  preparationStepTracks PreparationStepTrack[]
}

model PreparationStepTrack {
  id                            String                         @id
  createdAt                     DateTime                       @default(now())
  completed                     Boolean                        @default(false)
  quantity                      Int?
  comments                      String?
  completedComments             Boolean                        @default(false)
  preparationStepModifierTracks PreparationStepModifierTrack[]
  preparationStep               PreparationStep                @relation(fields: [preparationStepId], references: [id])
  preparationStepId             String
  preparationStepCategory       PreparationStepCategory        @relation(fields: [preparationStepCategoryId], references: [id], onDelete: Cascade)
  preparationStepCategoryId     String
}

model PreparationStepModifierTrack {
  id                     String               @id
  createdAt              DateTime             @default(now())
  completed              Boolean              @default(false)
  modifierGroupItem      ModifierGroupItem    @relation(fields: [modifierGroupItemId], references: [id])
  modifierGroupItemId    String
  preparationStepTrack   PreparationStepTrack @relation(fields: [preparationStepTrackId], references: [id], onDelete: Cascade)
  preparationStepTrackId String
}

model ProgressiveDiscount {
  id        String                    @id
  createdAt DateTime                  @default(now())
  completed Boolean                   @default(false)
  steps     ProgressiveDiscountStep[]
}

enum ProgressiveDiscountStepType {
  PERCENTAGEDISCOUNT
  GIFT
}

model ProgressiveDiscountStep {
  id                    String                      @id
  createdAt             DateTime                    @default(now())
  amount                Int
  discount              Int?
  discountType          ProgressiveDiscountStepType
  progressiveDiscount   ProgressiveDiscount         @relation(fields: [progressiveDiscountId], references: [id])
  progressiveDiscountId String
}

model File {
  id                 String              @id
  createdAt          DateTime            @default(now())
  name               String
  url                String
  size               Int
  product            Product?            @relation(fields: [productId], references: [id])
  productId          String?
  modifierGroupItems ModifierGroupItem[]
}

model ModifierGroup {
  id           String              @id
  createdAt    DateTime            @default(now())
  title        String
  required     Boolean             @default(false)
  type         ModifierGroupType?
  products     Product[]
  items        ModifierGroupItem[]
  minSelection Int?
  maxSelection Int?
}

model ModifierGroupItem {
  id                            String                         @id
  createdAt                     DateTime                       @default(now())
  name                          String
  price                         Int
  description                   String?
  photo                         File?                          @relation(fields: [fileId], references: [id])
  modifierGroup                 ModifierGroup?                 @relation(fields: [modifierGroupId], references: [id])
  modifierGroupId               String?
  fileId                        String?
  preparationStepModifierTracks PreparationStepModifierTrack[]
  orderProducts                 OrderProducts[]
}

enum ModifierGroupType {
  MULTI
  SINGLE
}

model Business {
  id        String   @id
  createdAt DateTime @default(now())
  name      String
  branches  Branch[]
}

model Branch {
  id         String    @id
  createdAt  DateTime  @default(now())
  name       String
  operationHours Json?
  address    Address?  @relation(fields: [addressId], references: [id])
  addressId  String?   @unique
  business   Business? @relation(fields: [businessId], references: [id])
  businessId String?
}

model Address {
  id            String   @id
  createdAt     DateTime @default(now())
  description   String
  googleMapsUrl String
  branch        Branch?
  orders        Order[]
}

model Product {
  id               String            @id
  createdAt        DateTime          @default(now())
  name             String
  description      String?
  price            Int?
  comparedAtPrice  Int?
  photos           File[]
  modifierGroups   ModifierGroup[]
  category         Category?         @relation(fields: [categoryId], references: [id])
  categoryId       String?
  OrderProducts    OrderProducts[]
  translations     Json?
  preparationSteps PreparationStep[]
}

model Category {
  id                        String                    @id
  createdAt                 DateTime                  @default(now())
  name                      String
  products                  Product[]
  preparationStepCategories PreparationStepCategory[]
}

model Campaign {
  id                String             @id
  createdAt         DateTime           @default(now())
  startedAt         DateTime?
  promotialMessages PromotialMessage[]
}

model Customer {
  id                  String             @id
  createdAt           DateTime           @default(now())
  name                String?
  email               String?
  phone               String?
  address             String?
  lastMessageSent     DateTime?
  orders              Order[]
  promotionalMessages PromotialMessage[]
  addresses           DeliveryAddress[]
}

model DeliveryAddress {
  id               String    @id
  createdAt        DateTime  @default(now())
  lat              String
  lng              String
  city             String
  zipCode          String
  State            String
  street           String
  number           String
  description      String
  complement       String?
  numberComplement String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  customerId       String?
  orders           Order[]
}

model Message {
  id                String             @id
  createdAt         DateTime           @default(now())
  name              String             @unique
  promotialMessages PromotialMessage[]
  content           String
  media             String?
}

model PromotialMessage {
  id         String    @id
  sentAt     DateTime  @default(now())
  Campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?
  message    Message   @relation(fields: [messageId], references: [id])
  messageId  String
  Customer   Customer  @relation(fields: [customerId], references: [id])
  customerId String
}

model Order {
  id                        String                    @id
  number                    String?
  createdAt                 DateTime                  @default(now())
  amount                    Int
  customer                  Customer                  @relation(fields: [customerId], references: [id])
  type                      OrderType                 @default(DELIVERY)
  paymentMethod             PaymentType               @default(CARD)
  tipAmount                 Int?
  address                   Address?                  @relation(fields: [addressId], references: [id])
  deliveryAddress           DeliveryAddress?          @relation(fields: [deliveryAddressId], references: [id])
  orderProducts             OrderProducts[]
  customerId                String
  externalId                String?
  addressId                 String?
  deliveryAddressId         String?
  preparationStepCategories PreparationStepCategory[]
}

enum PaymentType {
  CASH
  CARD
  ZELLE
}

enum OrderType {
  DELIVERY
  TAKEAWAY
}

model OrderProducts {
  id                 String              @id
  createdAt          DateTime            @default(now())
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId          String
  quantity           Int
  comments           String?
  modifierGroupItems ModifierGroupItem[]
  fullAmount         Int
  amount             Int
  order              Order?              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId            String?
}
